# =====================================================================
# CTI Agent — environment configuration
# Copy to `.env` and fill in. Anything left blank falls back to mocks.
# =====================================================================

# --- Local LLM (vLLM serving Qwen3, OpenAI-compatible API) ---
# Example vLLM launch on the GPU host:
#   vllm serve Qwen/Qwen3-30B-A3B-FP8 \
#     --host 0.0.0.0 --port 8000 \
#     --max-model-len 32768 --dtype auto \
#     --enable-reasoning --reasoning-parser deepseek_r1     # (optional)
#
# Then point LLM_BASE_URL at it. From inside docker compose, use
# host.docker.internal so the containers can reach your host GPU server.
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-30B-A3B-FP8
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=480

# Optional Qwen3 thinking-mode control (default off, works on all vLLM
# builds). Set to true to send `chat_template_kwargs.enable_thinking=false`
# via vLLM's extra_body passthrough. Older vLLM builds reject this with
# HTTP 400, so leave it off unless you've verified your vLLM accepts it.
LLM_DISABLE_THINKING=false

# --- Embedding model ---
EMBEDDING_MODEL=sentence-transformers/multi-qa-mpnet-base-dot-v1
EMBEDDING_DIM=768

# --- Vector DB (Milvus) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=cti_reports

# --- Elasticsearch ---
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=cti_reports

# --- Neo4j (STIX KG) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cti_password_123

# --- Postgres (IOC + feedback) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cti
POSTGRES_PASSWORD=cti_password_123
POSTGRES_DB=cti

# --- External enrichment APIs (optional - leave blank to use mock) ---
TAVILY_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
RECORDEDFUTURE_API_KEY=

# --- RSS feeds for ingestion (comma-separated) ---
RSS_FEEDS=https://feeds.feedburner.com/TheHackersNews,https://www.bleepingcomputer.com/feed/,https://krebsonsecurity.com/feed/,https://thehackernews.com/feeds/posts/default

# --- Agent config ---
MAX_VALIDATION_RETRIES=2
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
